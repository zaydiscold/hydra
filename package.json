{
  "name": "hydra",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "hydra": "bin/hydra.mjs"
  },
  "scripts": {
    "dev": "node scripts/free-dev-ports.mjs && concurrently -n server,client -c blue,green \"node server/index.js\" \"vite --host\"",
    "start": "node launch.js",
    "setup": "npm install && npx prisma db push --accept-data-loss && npx prisma generate && npm run build",
    "server": "node server/index.js",
    "client": "vite --host",
    "build": "vite build",
    "lint": "eslint .",
    "test:session-expiry": "DATABASE_URL=file:./prisma/dev.db node --test server/tests/session-expiry-effective.test.mjs",
    "test:ensure-session-backfill": "DATABASE_URL=file:./prisma/dev.db node --experimental-test-module-mocks --test server/tests/ensure-session-backfill.test.mjs",
    "test:otp-smoke": "node scripts/otp-start-smoke.mjs",
    "check:clerk": "node scripts/check-clerk-connectivity.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@vitejs/plugin-react": "^4.7.0",
    "bcryptjs": "^3.0.3",
    "concurrently": "^8.2.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.3",
    "node-fetch": "^2.7.0",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "uuid": "^13.0.0",
    "vite": "^5.4.21",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prisma": "^6.19.2"
  }
}
