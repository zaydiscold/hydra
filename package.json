{
  "name": "hydra",
  "private": true,
  "version": "1.0.7",
  "type": "module",
  "engines": {
    "node": ">=22.12"
  },
  "bin": {
    "hydra": "bin/hydra.mjs"
  },
  "scripts": {
    "// ─── Development ───────────────────────────────────────────────────────": "",
    "dev": "node scripts/free-dev-ports.mjs && concurrently -n server,client -c blue,green \"node server/standalone.js\" \"vite --host\"",
    "dev:electron": "node scripts/dev-electron.mjs",
    "server": "node server/standalone.js",
    "client": "vite --host",
    "// ─── Build ─────────────────────────────────────────────────────────────": "",
    "build": "vite build",
    "electron:prepare": "node scripts/prepare-electron-resources.mjs",
    "electron:build": "npm run build && npm run electron:prepare && electron-builder",
    "electron:build:mac-arm64": "npm run build && HYDRA_BUILD_TARGET=darwin-arm64 npm run electron:prepare && electron-builder --mac zip --arm64",
    "electron:build:mac-x64": "npm run build && HYDRA_BUILD_TARGET=darwin-x64 npm run electron:prepare && electron-builder --mac zip --x64",
    "electron:build:dmg": "npm run build && HYDRA_BUILD_TARGET=darwin-arm64 npm run electron:prepare && electron-builder --mac dmg --arm64",
    "electron:build:win": "npm run build && HYDRA_BUILD_TARGET=win32-x64 npm run electron:prepare && electron-builder --win nsis --x64",
    "electron:build:linux": "npm run build && HYDRA_BUILD_TARGET=linux-x64 npm run electron:prepare && electron-builder --linux AppImage --x64",
    "electron:smoke": "node scripts/smoke-electron-package.mjs",
    "electron:open:mac-arm64": "node scripts/open-packaged-app.mjs release/mac-arm64/Hydra.app",
    "// ─── Testing ───────────────────────────────────────────────────────────": "",
    "pretest": "prisma db push --skip-generate && prisma generate",
    "test": "npm run test:test-chain-completeness && npm run test:session-expiry && npm run test:ensure-session-backfill && npm run test:session-refresh-contract && npm run test:management-key-backfill && npm run test:config && npm run test:filesystem-permissions && npm run test:user-prefs && npm run test:local-secrets && npm run test:account-proxy-pool && npm run test:auth-status && npm run test:auth-cookie && npm run test:webhooks && npm run test:upstream-health && npm run test:health-pinger && npm run test:proxy-gate && npm run test:task-supervisor && npm run test:background-failure-visibility && npm run test:proxy-sse && npm run test:request-log-buffer && npm run test:db-proxy-cache && npm run test:schema-self-heal-backups && npm run test:electron-url-allowlist && npm run test:api-integration && npm run test:browser-isolation && npm run test:openapi-map && npm run test:cli && npm run test:ui-static && npm run test:docker-smoke && npm run test:workflow-contract && npm run test:gzip-middleware && npm run test:error-boundary-sanitization && npm run test:prisma-error-classification && npm run test:phase1-backward-compat && npm run test:electron",
    "test:electron": "npm run test:electron-server-extract && npm run test:electron-launch-compat && npm run test:electron-data-path && npm run test:electron-ipc-contract && npm run test:electron-main-process && npm run test:electron-path-allowlist && npm run test:schema-hash && npm run test:electron-prisma-asar",
    "test:test-chain-completeness": "node --test server/tests/test-chain-completeness.test.mjs",
    "test:session-expiry": "DATABASE_URL=file:./prisma/dev.db node --test server/tests/session-expiry-effective.test.mjs",
    "test:ensure-session-backfill": "DATABASE_URL=file:./prisma/dev.db node --experimental-test-module-mocks --test server/tests/ensure-session-backfill.test.mjs",
    "test:session-refresh-contract": "node --test server/tests/session-refresh-contract.test.mjs",
    "test:config": "node --test server/tests/config-validation.test.mjs",
    "test:filesystem-permissions": "node --test server/tests/filesystem-permissions.test.mjs",
    "test:user-prefs": "node --experimental-test-module-mocks --test server/tests/user-prefs.test.mjs",
    "test:local-secrets": "node --test server/tests/local-secrets.test.mjs",
    "test:account-proxy-pool": "node --test server/tests/account-proxy-pool.test.mjs",
    "test:auth-status": "node --test server/tests/auth-setup-status.test.mjs",
    "test:auth-cookie": "node --experimental-test-module-mocks --test server/tests/auth-cookie.test.mjs",
    "test:webhooks": "node --test server/tests/clerk-webhook-session-revoke.test.mjs",
    "test:upstream-health": "node --test server/tests/upstream-health.test.mjs",
    "test:health-pinger": "node --test server/tests/health-pinger-contract.test.mjs",
    "test:proxy-gate": "node --test server/tests/proxy-gate.test.mjs",
    "test:task-supervisor": "node --experimental-test-module-mocks --test server/tests/task-supervisor.test.mjs",
    "test:background-failure-visibility": "node --test server/tests/background-failure-visibility.test.mjs",
    "test:proxy-sse": "node --test server/tests/sse-stream.test.mjs",
    "test:request-log-buffer": "node --experimental-test-module-mocks --test server/tests/request-log-buffer.test.mjs",
    "test:db-proxy-cache": "node --experimental-test-module-mocks --test server/tests/db-proxy-cache.test.mjs",
    "test:schema-self-heal-backups": "node --experimental-test-module-mocks --test server/tests/schema-self-heal-backups.test.mjs",
    "test:electron-url-allowlist": "node --experimental-test-module-mocks --test server/tests/electron-url-allowlist.test.mjs",
    "test:api-integration": "node --test --test-isolation=none server/tests/electron-api-integration.test.mjs",
    "test:browser-isolation": "node --test server/tests/playwright-isolation.test.mjs",
    "test:openapi-map": "node --test server/tests/hydra-openapi-map.test.mjs",
    "test:cli": "node --test server/tests/cli.test.mjs",
    "test:ui-static": "node --test server/tests/ui-static-contract.test.mjs",
    "test:docker-smoke": "node --test server/tests/docker-smoke-script.test.mjs",
    "test:workflow-contract": "node --test server/tests/workflow-contract.test.mjs",
    "test:gzip-middleware": "node --experimental-test-module-mocks --test server/tests/gzip-middleware.test.mjs",
    "test:error-boundary-sanitization": "node --test server/tests/error-boundary-sanitization.test.mjs",
    "test:prisma-error-classification": "node --test server/tests/prisma-error-classification.test.mjs",
    "test:phase1-backward-compat": "node --test server/tests/phase1-backward-compat.test.mjs",
    "test:electron-prisma-asar": "node --test server/tests/electron-prisma-asar.test.mjs",
    "test:otp-smoke": "node scripts/otp-start-smoke.mjs",
    "test:electron-server-extract": "DATABASE_URL=file:./prisma/dev.db node --experimental-test-module-mocks --test server/tests/electron-server-extract.test.mjs",
    "test:electron-launch-compat": "node --experimental-test-module-mocks --test server/tests/electron-launch-compat.test.mjs",
    "test:electron-data-path": "node --experimental-test-module-mocks --test server/tests/electron-data-path.test.mjs",
    "test:electron-ipc-contract": "node --test server/tests/electron-ipc-contract.test.mjs",
    "test:electron-main-process": "node --test electron/tests/main-process.test.mjs",
    "test:electron-path-allowlist": "node --test electron/tests/path-allowlist.test.mjs",
    "test:schema-hash": "node --experimental-test-module-mocks --test server/tests/schema-hash.test.mjs",
    "test:management-key-backfill": "DATABASE_URL=file:./prisma/dev.db node --experimental-test-module-mocks --test server/tests/management-key-backfill.test.mjs",
    "// ─── Lint & Quality ────────────────────────────────────────────────────": "",
    "lint": "eslint .",
    "gate": "node scripts/integration-gate.mjs",
    "// ─── Preview & Start ───────────────────────────────────────────────────": "",
    "start": "node scripts/launch.js",
    "preview": "npm run preview:electron",
    "preview:electron": "npm run build && electron .",
    "preview:web": "vite preview",
    "preview:static": "npm run build && node server/standalone.js",
    "start:electron": "npm run preview:electron",
    "// ─── Docker ──────────────────────────────────────────────────────────": "",
    "docker:config": "docker compose config",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:smoke": "node scripts/docker-smoke.mjs",
    "// ─── Setup & Tools ─────────────────────────────────────────────────────": "",
    "openapi:hydra": "node scripts/generate-hydra-openapi.mjs",
    "setup": "npm install && prisma db push --skip-generate && prisma generate && npm run build",
    "link": "npm link",
    "check:clerk": "node scripts/recon/check-clerk-connectivity.mjs",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@sentry/electron": "^7.13.0",
    "animejs": "^4.4.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.3",
    "p-limit": "^7.3.0",
    "playwright-core": "^1.58.2",
    "undici": "^7.25.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^8.2.2",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "node-fetch": "^2.7.0",
    "prisma": "^6.19.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "sharp": "^0.34.5",
    "vite": "^8.0.13"
  },
  "optionalDependencies": {
    "playwright": "^1.58.2"
  },
  "description": "Hydra is a professional, high-intensity local management dashboard for OpenRouter account fleets. It provides a single, locally-secured interface to manage balances, rotate API keys, and perform bulk operations across dozens of accounts simultaneously.",
  "repository": {
    "type": "git",
    "url": "https://github.com/zaydiscold/hydra.git"
  },
  "main": "electron/main.js",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
