{
  "name": "hydra",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "hydra": "bin/hydra.mjs"
  },
  "scripts": {
    "dev": "node scripts/free-dev-ports.mjs && concurrently -n server,client -c blue,green \"node server/standalone.js\" \"vite --host\"",
    "start": "node scripts/launch.js",
    "setup": "npm install && npx prisma db push --accept-data-loss && npx prisma generate && npm run build",
    "server": "node server/index.js",
    "client": "vite --host",
    "build": "vite build",
    "lint": "eslint .",
    "test:session-expiry": "DATABASE_URL=file:./prisma/dev.db node --test server/tests/session-expiry-effective.test.mjs",
    "test:ensure-session-backfill": "DATABASE_URL=file:./prisma/dev.db node --experimental-test-module-mocks --test server/tests/ensure-session-backfill.test.mjs",
    "test:otp-smoke": "node scripts/otp-start-smoke.mjs",
    "test:electron-server-extract": "DATABASE_URL=file:./prisma/dev.db node --experimental-test-module-mocks --test server/tests/electron-server-extract.test.mjs",
    "test:electron-launch-compat": "node --test server/tests/electron-launch-compat.test.mjs",
    "test:electron-data-path": "node --test server/tests/electron-data-path.test.mjs",
    "test:management-key-backfill": "DATABASE_URL=file:./prisma/dev.db node --experimental-test-module-mocks --test server/tests/management-key-backfill.test.mjs",
    "pretest": "npx prisma db push --accept-data-loss && npx prisma generate",
    "test": "npm run test:session-expiry && npm run test:ensure-session-backfill",
    "check:clerk": "node scripts/check-clerk-connectivity.mjs",
    "preview": "vite preview",
    "dev:electron": "concurrently -k \"vite\" \"electron .\"",
    "electron:build": "electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "@vitejs/plugin-react": "^4.7.0",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.3",
    "node-fetch": "^2.7.0",
    "p-limit": "^7.3.0",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "react-virtualized-auto-sizer": "^2.0.3",
    "react-window": "^2.2.7",
    "uuid": "^13.0.0",
    "vite": "^5.4.21",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "electron-log": "^5.4.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prisma": "^6.19.2",
    "sharp": "^0.34.5"
  },
  "description": "Hydra is a professional, high-intensity local management dashboard for OpenRouter account fleets. It provides a single, locally-secured interface to manage balances, rotate API keys, and perform bulk operations across dozens of accounts simultaneously.",
  "main": "electron/main.js",
  "directories": {
    "doc": "docs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
